rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /audio-evaluations/{userId}/{allPaths=**} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
      allow update: if false;
      allow delete: if isOwner(userId);
      allow list: if false;
    }

    // Profile pictures. Publicly readable because avatars are shown to friends
    // and duel opponents; only the owner may upload, images only, ≤5MB.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp|gif)');
      allow delete: if isOwner(userId);
      allow list: if false;
    }
  }
}
