{
  "version": 2,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "experimentalServices": {
    "vivid-lingua": {
      "type": "web",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm install --include=dev && npm run build"
    }
  }
}
